DATABASE_URL=
ADMIN_PASSWORD=
SESSION_SECRET=
NODE_ENV=production

# Map preview (optional): rustmaps | playrust | custom
# MAP_PREVIEW_PROVIDER=rustmaps
# MAP_PREVIEW_URL_TEMPLATE=https://example.com/map/{seed}/{size}

# Background map refresh: set CRON_SECRET and call POST /api/internal/refresh-maps
# MAP_REFRESH_ENABLED=false
# CRON_SECRET=

# Twitch integration (OAuth + EventSub)
# TWITCH_CLIENT_ID=        # From Twitch Developer Console
# TWITCH_CLIENT_SECRET=    # From Twitch Developer Console
# TWITCH_REDIRECT_URI=     # e.g. https://yourdomain.com/api/twitch/callback
# TWITCH_WEBHOOK_CALLBACK_URL=  # e.g. https://yourdomain.com/api/twitch/webhook (must be HTTPS in production)
# TWITCH_EVENTSUB_SECRET=  # Random string you choose; used to verify webhook signatures
# ENCRYPTION_KEY=          # 32+ chars for encrypting Twitch tokens (hex or string)

# Realtime gateway + API (optional)
# GATEWAY_SECRET=
# GATEWAY_PORT=3040
# API_PORT=3001

# TikFinity webhook → RCON (RustChaos)
# TIKFINITY_SERVER_ID=   # Rust server ID from your dashboard (which server receives TikTok triggers)
# APP_URL=               # Public base URL (e.g. https://rustmaxx.com) so webhook URL is correct in admin
