DATABASE_URL=
ADMIN_PASSWORD=
SESSION_SECRET=
NODE_ENV=production

# Map preview (optional): rustmaps | playrust | custom
# MAP_PREVIEW_PROVIDER=rustmaps
# MAP_PREVIEW_URL_TEMPLATE=https://example.com/map/{seed}/{size}

# Background map refresh: set CRON_SECRET and call POST /api/internal/refresh-maps
# MAP_REFRESH_ENABLED=false
# CRON_SECRET=

# Twitch integration (realtime gateway + API)
# GATEWAY_SECRET=    # Shared secret for plugin auth
# GATEWAY_PORT=3040
# API_PORT=3001
